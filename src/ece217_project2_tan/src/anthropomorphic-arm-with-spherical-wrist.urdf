<?xml version="1.0" encoding="UTF-8"?>

<robot name="project2_robot">

  <material name="blue">

    <color rgba="0.0 0.0 1.0 1.0"/>

  </material>

 

  <material name="red">

    <color rgba="1.0 0.0 0.0 1.0"/>

  </material>

 

  <material name="green">

    <color rgba="0.0 1.0 0.0 1.0"/>

  </material>

 

  <material name="yellow">

    <color rgba="1.0 1.0 0.0 1.0"/>

  </material>

 

  <link name="base_link">

    <visual>

      <geometry>

        <box size="0.25 0.25 0.01"/>

      </geometry>

      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 -0.01"/>

      <material name="red"/>

    </visual>

  </link>

 

  <link name="link1a">

    <visual>

      <geometry>

        <cylinder length="0.2" radius="0.1"/>

      </geometry>

      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>

      <material name="green"/>

    </visual>

  </link>

 

  <link name="link1b">

    <visual>

      <geometry>

        <box size="0.1 0.1 1.0"/>

      </geometry>

      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.5"/>

      <material name="blue"/>

    </visual>

  </link>

 

  <link name="link1c"/>

 

  <link name="link2a">

    <visual>

      <geometry>

        <cylinder length="0.2" radius="0.1"/>

      </geometry>

      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>

      <material name="yellow"/>

    </visual>

  </link>

 

  <link name="link2b">

    <visual>

      <geometry>

        <box size="1.0 0.1 0.1"/>

      </geometry>

      <origin rpy="0.0 0.0 0.0" xyz="0.5 0.0 0.0"/>

      <material name="blue"/>

    </visual>

  </link>

 

  <link name="link3a">

    <visual>

      <geometry>

        <cylinder length="0.2" radius="0.1"/>

      </geometry>

      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>

      <material name="yellow"/>

    </visual>

  </link>

 

  <link name="link3b"/>

 

  <link name="link4a">

    <visual>

      <geometry>

        <cylinder length="0.2" radius="0.1"/>

      </geometry>

      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>

      <material name="yellow"/>

    </visual>

  </link>

 

  <link name="link4b">

    <visual>

      <geometry>

        <box size="0.1 0.1 0.5"/>

      </geometry>

      <origin rpy="0.0 0.0 0.0" xyz="0 0.0 0.25"/>

      <material name="blue"/>

    </visual>

  </link>

 

  <link name="link4c"/>

 

  <link name="link5a">

    <visual>

      <geometry>

        <cylinder length="0.2" radius="0.1"/>

      </geometry>

      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>

      <material name="yellow"/>

    </visual>

  </link>

 

  <link name="link5b"/>

 

  <link name="link6a">

    <visual>

      <geometry>

        <cylinder length="0.2" radius="0.1"/>

      </geometry>

      <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 0.0"/>

      <material name="yellow"/>

    </visual>

  </link>

 

  <link name="link6b">

    <visual>

      <geometry>

        <box size="0.1 0.1 0.5"/>

      </geometry>

      <origin rpy="0.0 0.0 0.0" xyz="0 0.0 0.25"/>

      <material name="blue"/>

    </visual>

  </link>

 

  <link name="link6c"/>

 

  <joint name="basefixedjoint" type="fixed">

    <origin rpy="0.0 0.0 0" xyz="0.0 0.0 0.0"/>

    <parent link="base_link"/>

    <child link="link1a"/>

  </joint>

 

  <joint name="joint1theta" type="revolute">

    <axis xyz="0 0 1"/>

    <limit effort="1000.0" lower="-1.57" upper="1.57" velocity="1.0"/>

    <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>

    <parent link="link1a"/>

    <child link="link1b"/>

  </joint>

 

  <joint name="joint1d" type="fixed">

    <origin rpy="0 0 0" xyz="0.0 0.0 1.0"/>

    <parent link="link1b"/>

    <child link="link1c"/>

  </joint>

 

  <joint name="joint1alpha" type="fixed">

    <origin rpy="1.57 0 0" xyz="0 0 0"/>

    <parent link="link1c"/>

    <child link="link2a"/>

  </joint>

 

  <joint name="joint2theta" type="revolute">

    <axis xyz="0 0 1"/>

    <limit effort="1000.0" lower="-1.57" upper="1.57" velocity="1.0"/>

    <origin rpy="0 0 0" xyz="0.0 0.0 0.0"/>

    <parent link="link2a"/>

    <child link="link2b"/>

  </joint>

 

  <joint name="joint2a" type="fixed">

    <origin rpy="0.0 0.0 0" xyz="1.0 0.0 0.0"/>

    <parent link="link2b"/>

    <child link="link3a"/>

  </joint>

 

  <joint name="joint3theta" type="revolute">

    <axis xyz="0 0 1"/>

    <limit effort="1000.0" lower="-1.57" upper="1.57" velocity="1.0"/>

    <origin rpy="0.0 0 0" xyz="0.0 0.0 0.0"/>

    <parent link="link3a"/>

    <child link="link3b"/>

  </joint>

  

  <joint name="joint3alpha" type="fixed">

    <origin rpy="1.57 0 0" xyz="0 0 0"/>

    <parent link="link3b"/>

    <child link="link4a"/>

  </joint>

 

  <joint name="joint4theta" type="revolute">

    <axis xyz="0 0 1"/>

    <limit effort="1000.0" lower="-1.57" upper="1.57" velocity="1.0"/>

    <origin rpy="0.0 0 0" xyz="0.0 0.0 0.0"/>

    <parent link="link4a"/>

    <child link="link4b"/>

  </joint> 

 

  <joint name="joint4d" type="fixed">

    <origin rpy="0 0 0" xyz="0.0 0.0 0.5"/>

    <parent link="link4b"/>

    <child link="link4c"/>

  </joint>

    

  <joint name="joint4alpha" type="fixed">

    <origin rpy="-1.57 0 0" xyz="0 0 0"/>

    <parent link="link4c"/>

    <child link="link5a"/>

  </joint>

 

  <joint name="joint5theta" type="revolute">

    <axis xyz="0 0 1"/>

    <limit effort="1000.0" lower="-1.57" upper="1.57" velocity="1.0"/>

    <origin rpy="0.0 0 0" xyz="0.0 0.0 0.0"/>

    <parent link="link5a"/>

    <child link="link5b"/>

  </joint>

 

  <joint name="joint5alpha" type="fixed">

    <origin rpy="1.57 0 0" xyz="0 0 0"/>

    <parent link="link5b"/>

    <child link="link6a"/>

  </joint>

 

  <joint name="joint6theta" type="revolute">

    <axis xyz="0 0 1"/>

    <limit effort="1000.0" lower="-1.57" upper="1.57" velocity="1.0"/>

    <origin rpy="0.0 0 0" xyz="0.0 0.0 0.0"/>

    <parent link="link6a"/>

    <child link="link6b"/>

  </joint>

 

  <joint name="joint6d" type="fixed">

    <origin rpy="0 0 0" xyz="0.0 0.0 0.5"/>

    <parent link="link6b"/>

    <child link="link6c"/>

  </joint>

 

</robot> 
